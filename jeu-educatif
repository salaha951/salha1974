let G={score:0,lives:3,badges:[],levelProgress:{},curLevel:0,curQ:0,curLevelPts:0,streak:0,timerInterval:null,timeLeft:15,answered:false};

function resetAll(){G={score:0,lives:3,badges:[],levelProgress:{},curLevel:0,curQ:0,curLevelPts:0,streak:0,timerInterval:null,timeLeft:15,answered:false};updateHUD();buildMap();showScreen('scMap');}

function buildMap(){
  const grid=document.getElementById('levelsGrid');grid.innerHTML='';
  LEVELS.forEach((lv,i)=>{
    const prog=G.levelProgress[lv.id];const locked=i>0&&!G.levelProgress[LEVELS[i-1].id];const done=!!prog;const stars=prog?prog.stars:0;
    const div=document.createElement('div');div.className='lvl-card'+(locked?' locked':'')+(done?' done':'');
    div.innerHTML=`<div class="lvl-badge">مستوى ${i+1}</div><div class="lvl-icon">${lv.icon}</div><div class="lvl-name">${lv.name}</div><div class="lvl-desc">${lv.desc}</div><div class="lvl-stars">${stars>0?'⭐'.repeat(stars)+'☆'.repeat(3-stars):'☆☆☆'}</div>`;
    if(!locked)div.onclick=()=>startLevel(i);grid.appendChild(div);
  });
}

function startLevel(idx){G.curLevel=idx;G.curQ=0;G.curLevelPts=0;G.lives=3;G.streak=0;updateHUD();renderQ();showScreen('scQ');}
function restartCurrentLevel(){startLevel(G.curLevel);}
function showMap(){buildMap();showScreen('scMap');}

function renderQ(){
  const lv=LEVELS[G.curLevel];const q=lv.questions[G.curQ];const total=lv.questions.length;
  document.getElementById('bIcon').textContent=lv.icon;document.getElementById('bName').textContent=lv.name;
  document.getElementById('bProg').textContent=`السؤال ${G.curQ+1} من ${total}`;
  document.getElementById('bFill').style.width=((G.curQ/total)*100)+'%';
  const catEl=document.getElementById('qCat');catEl.className='qcat '+lv.cat;catEl.textContent=lv.catName;
  document.getElementById('qIcon').textContent=q.icon;document.getElementById('qTitle').textContent=q.title;document.getElementById('qStory').textContent=q.story;
  document.getElementById('fbBox').className='fb-box';document.getElementById('nxtBtn').className='nxt-btn';G.answered=false;
  const grid=document.getElementById('choices');grid.innerHTML='';
  const letters=['أ','ب','ج','د'];
  q.choices.forEach((c,i)=>{const btn=document.createElement('button');btn.className='cbtn';btn.innerHTML=`<span class="cletter">${letters[i]}</span>${c}`;btn.onclick=()=>pick(i,btn);grid.appendChild(btn);});
  startTimer();
}

function startTimer(){
  clearInterval(G.timerInterval);G.timeLeft=15;
  const bar=document.getElementById('timerBar');bar.style.width='100%';bar.style.background='linear-gradient(90deg,var(--green),var(--cyan))';
  G.timerInterval=setInterval(()=>{
    G.timeLeft--;const pct=(G.timeLeft/15)*100;bar.style.width=pct+'%';
    if(G.timeLeft<=5)bar.style.background='linear-gradient(90deg,var(--red),var(--orange))';
    else if(G.timeLeft<=9)bar.style.background='linear-gradient(90deg,var(--yellow),var(--orange))';
    if(G.timeLeft<=0){clearInterval(G.timerInterval);if(!G.answered)timeOut();}
  },1000);
}

function timeOut(){
  G.answered=true;G.streak=0;G.lives--;
  const q=LEVELS[G.curLevel].questions[G.curQ];
  const btns=document.querySelectorAll('.cbtn');
  btns.forEach((b,i)=>{b.classList.add('disabled');if(i===q.correct)b.classList.add('correct');});
  showFeedback(false,'⏰ انتهى الوقت!',`الجواب الصحيح هو: ${q.choices[q.correct]}`,q.tip);
  updateHUD();document.getElementById('nxtBtn').className='nxt-btn show';
  document.getElementById('nxtBtn').onclick=advanceQ;
}

function pick(idx,btn){
  if(G.answered)return;G.answered=true;clearInterval(G.timerInterval);
  const lv=LEVELS[G.curLevel];const q=lv.questions[G.curQ];
  const allBtns=document.querySelectorAll('.cbtn');allBtns.forEach(b=>b.classList.add('disabled'));
  const correct=idx===q.correct;
  if(correct){
    btn.classList.add('correct');G.streak++;
    const bonusMult=G.streak>=5?2:G.streak>=3?1.5:1;
    const pts=Math.round(q.pts*bonusMult+(G.timeLeft*3));
    G.score+=pts;G.curLevelPts+=pts;
    showFeedback(true,'✅ إجابة صحيحة!',q.good,q.tip);
    showPtsPopup(btn,'+'+pts);spawnSparks(btn);spawnConfetti(20);
    if(G.streak>=3)showStreak();updateHUD(true);
  } else {
    btn.classList.add('wrong');allBtns[q.correct].classList.add('correct');
    G.streak=0;G.lives--;
    showFeedback(false,'❌ إجابة خاطئة!',q.bad,q.tip);
    shakeCard();updateHUD(false,true);
  }
  document.getElementById('nxtBtn').className='nxt-btn show';
  document.getElementById('nxtBtn').onclick=advanceQ;
}

function advanceQ(){
  if(G.lives<=0){showScreen('scGO');document.getElementById('goScore').textContent=G.score;return;}
  G.curQ++;
  if(G.curQ>=LEVELS[G.curLevel].questions.length)levelComplete();else renderQ();
}

function levelComplete(){
  const lv=LEVELS[G.curLevel];
  const maxPts=lv.questions.reduce((a,q)=>a+q.pts,0);
  const pct=G.curLevelPts/maxPts;
  const stars=G.lives===3&&pct>=.8?3:G.lives>=2&&pct>=.5?2:1;
  G.levelProgress[lv.id]={done:true,stars,pts:G.curLevelPts};
  if(!G.badges.find(b=>b.icon===lv.badge)){G.badges.push({icon:lv.badge,name:lv.badgeName});showBadgePopup(lv.badge,lv.badgeName);}
  updateHUD();spawnConfetti(40);
  document.getElementById('lcIcon').textContent=stars===3?'🏆':stars===2?'🥈':'🥉';
  document.getElementById('lcTitle').textContent=stars===3?'مذهل! أداء مثالي!':stars===2?'أحسنت! عمل رائع!':'أتممت المستوى!';
  document.getElementById('lcPts').textContent=G.curLevelPts;
  document.getElementById('lcStars').textContent='⭐'.repeat(stars)+'☆'.repeat(3-stars);
  document.getElementById('lcBadgeIcon').textContent=lv.badge;
  document.getElementById('lcBadgeName').textContent=lv.badgeName;
  document.getElementById('lcTip').innerHTML=lv.levelTip;
  const nxtBtn=document.getElementById('lcNext');const nextIdx=G.curLevel+1;
  if(nextIdx<LEVELS.length){nxtBtn.textContent='المستوى التالي ←';nxtBtn.onclick=()=>startLevel(nextIdx);}
  else{nxtBtn.textContent='🏆 شاشة النهاية';nxtBtn.onclick=showFinalScreen;}
  showScreen('scLC');
}

function showFinalScreen(){
  spawnConfetti(60);
  const rank=G.score>=1800?'🥇 أسطورة الأمان الرقمي':G.score>=1200?'🥈 محترف الأمان':G.score>=700?'🥉 حارس جيد':'🌱 متعلّم نشيط';
  const trophy=G.score>=1800?'🏆':G.score>=1200?'🥈':'🎖️';
  document.getElementById('finalTrophy').textContent=trophy;
  document.getElementById('finalTitle').textContent='أنت حارس الإنترنت الأسطوري!';
  document.getElementById('finalScore').textContent=G.score;
  document.getElementById('finalBadges').textContent=G.badges.map(b=>b.icon).join(' ')||'🌱';
  document.getElementById('finalRank').textContent=rank;
  const list=document.getElementById('tipsList');list.innerHTML='';
  FINAL_TIPS.forEach(t=>{const li=document.createElement('li');li.textContent=t;list.appendChild(li);});
  showScreen('scFinal');
}

function showFeedback(good,title,msg,tip){
  const box=document.getElementById('fbBox');box.className='fb-box '+(good?'good':'bad')+' show';
  document.getElementById('fbTitle').textContent=title;document.getElementById('fbMsg').textContent=msg;document.getElementById('fbTip').innerHTML=tip;
}

function updateHUD(scoreChanged=false,livesChanged=false){
  document.getElementById('hScore').textContent=G.score;
  document.getElementById('hLives').textContent='🛡'.repeat(Math.max(0,G.lives))||'💔';
  document.getElementById('hLevel').textContent=`${G.curLevel+1}/${LEVELS.length}`;
  document.getElementById('hBadge').textContent=G.badges.length?G.badges.slice(-3).map(b=>b.icon).join(''):'—';
  if(scoreChanged)pulse('hScore');if(livesChanged)pulse('hLives');
}

function pulse(id){const el=document.getElementById(id);el.classList.remove('pulse-anim');void el.offsetWidth;el.classList.add('pulse-anim');}

function spawnConfetti(n=25){
  const fx=document.getElementById('fx');
  const colors=['#00e5c8','#2979ff','#8b5cf6','#f472b6','#10d97a','#ffd32a','#ff4757','#ff8c00'];
  for(let i=0;i<n;i++){
    const c=document.createElement('div');c.className='cf';const isCircle=Math.random()>.5;
    c.style.cssText=`left:${Math.random()*100}%;background:${colors[Math.floor(Math.random()*colors.length)]};width:${Math.random()*10+5}px;height:${Math.random()*10+5}px;--r:${isCircle?'50%':'2px'};--d:${(Math.random()*1.8+1).toFixed(2)}s;--dl:${(Math.random()*.6).toFixed(2)}s;--rot:${Math.random()>.5?'':'-'}${Math.floor(Math.random()*720+360)}deg;`;
    fx.appendChild(c);setTimeout(()=>c.remove(),2500);
  }
}

function spawnSparks(btn){
  const rect=btn.getBoundingClientRect();const cx=rect.left+rect.width/2;const cy=rect.top+rect.height/2;
  const fx=document.getElementById('fx');const colors=['#00e5c8','#ffd32a','#10d97a','#2979ff'];
  for(let i=0;i<10;i++){
    const s=document.createElement('div');s.className='spark';const ang=Math.random()*Math.PI*2;const dist=30+Math.random()*50;
    s.style.cssText=`width:8px;height:8px;left:${cx-4}px;top:${cy-4}px;background:${colors[i%colors.length]};--tx:${Math.cos(ang)*dist}px;--ty:${Math.sin(ang)*dist}px;`;
    fx.appendChild(s);setTimeout(()=>s.remove(),700);
  }
}

function showPtsPopup(btn,text){
  const rect=btn.getBoundingClientRect();const el=document.createElement('div');el.className='pts-popup';el.textContent=text;
  el.style.cssText=`left:${rect.left+rect.width/2-30}px;top:${rect.top-10}px;`;
  document.body.appendChild(el);setTimeout(()=>el.remove(),1300);
}

function showBadgePopup(icon,name){
  const el=document.createElement('div');el.className='badge-popup';
  el.innerHTML=`<div class="badge-popup-icon">${icon}</div><div class="badge-popup-name">🏅 ${name}</div>`;
  document.body.appendChild(el);setTimeout(()=>el.remove(),2200);
}

function showStreak(){
  const msgs=['🔥 تسلسل ×3!','🔥🔥 تسلسل ×4!','🔥🔥🔥 تسلسل ×5!','⚡ لا يُوقف! ×'+G.streak];
  const el=document.createElement('div');el.className='streak-banner';
  el.textContent=msgs[Math.min(G.streak-3,3)]||msgs[3];
  document.body.appendChild(el);setTimeout(()=>el.remove(),2000);
}

function shakeCard(){
  const card=document.getElementById('qCard')||document.querySelector('.qcard');if(!card)return;
  card.style.transform='translateX(10px)';setTimeout(()=>{card.style.transform='translateX(-10px)';},80);
  setTimeout(()=>{card.style.transform='translateX(8px)';},160);setTimeout(()=>{card.style.transform='translateX(-6px)';},240);
  setTimeout(()=>{card.style.transform='translateX(0)';},320);
}

function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>{s.classList.remove('active');s.style.display='none';});
  const el=document.getElementById(id);el.style.display='block';el.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}

resetAll();
</script>
</body>
</html>
